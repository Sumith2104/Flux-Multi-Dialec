{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource" }],
  "__requires": [{ "type": "grafana", "version": "9.0.0" }],
  "title": "Fluxbase Ingestion Pipeline",
  "uid": "fluxbase-ingestion-v1",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Rows / Second",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 5000 }
          ]}
        }
      },
      "targets": [{ "expr": "ingestion_rows_per_second", "legendFormat": "rows/s" }]
    },
    {
      "id": 2, "type": "stat", "title": "Active Workers",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "blue", "value": null }
        ]}}
      },
      "targets": [{ "expr": "ingestion_worker_count", "legendFormat": "workers" }]
    },
    {
      "id": 3, "type": "stat", "title": "Queue Depth (Normal)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 500 },
          { "color": "red", "value": 2000 }
        ]}}
      },
      "targets": [{ "expr": "ingestion_queue_depth{queue=\"normal\"}", "legendFormat": "depth" }]
    },
    {
      "id": 4, "type": "stat", "title": "Failure Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.02 },
            { "color": "red", "value": 0.05 }
          ]}
        }
      },
      "targets": [{ "expr": "ingestion_failure_rate", "legendFormat": "failure rate" }]
    },
    {
      "id": 5, "type": "stat", "title": "DLQ Size",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ]}}
      },
      "targets": [{ "expr": "ingestion_queue_depth{queue=\"dlq\"}", "legendFormat": "dlq" }]
    },
    {
      "id": 6, "type": "stat", "title": "Latency P99",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 2000 }
          ]}
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(ingestion_insert_latency_ms_bucket[5m]))",
        "legendFormat": "p99"
      }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Throughput — Rows/sec over time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "rows/s", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        { "expr": "rate(ingestion_rows_ingested_total[1m]) * 60", "legendFormat": "ingested/sec" },
        { "expr": "rate(ingestion_rows_failed_total[1m]) * 60", "legendFormat": "failed/sec" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Queue Depth over time",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "targets": [
        { "expr": "ingestion_queue_depth{queue=\"normal\"}", "legendFormat": "normal" },
        { "expr": "ingestion_queue_depth{queue=\"high\"}", "legendFormat": "high-priority" },
        { "expr": "ingestion_queue_depth{queue=\"dlq\"}", "legendFormat": "DLQ" }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Insert Latency Percentiles",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(ingestion_insert_latency_ms_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(ingestion_insert_latency_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(ingestion_insert_latency_ms_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 13, "type": "timeseries", "title": "Worker Count (Auto-Scale)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" } }
      },
      "targets": [
        { "expr": "ingestion_worker_count", "legendFormat": "workers" },
        { "expr": "ingestion_batch_size_current", "legendFormat": "batch size" },
        { "expr": "ingestion_concurrency_current", "legendFormat": "concurrency" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "Cumulative Rows (Total Ingested vs Failed)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 6 },
      "targets": [
        { "expr": "ingestion_rows_ingested_total", "legendFormat": "total ingested" },
        { "expr": "ingestion_rows_failed_total", "legendFormat": "total failed" },
        { "expr": "ingestion_rows_dlq_total", "legendFormat": "total DLQ" }
      ]
    }
  ]
}
